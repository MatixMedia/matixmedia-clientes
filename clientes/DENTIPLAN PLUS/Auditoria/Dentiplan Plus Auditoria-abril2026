];
const funnelEl = document.getElementById('funnel');
// For bar widths, normalize volumes relative to impressions and rates relative to 100%
funnelEl.innerHTML = stages.map((s,i) => {
  let width, display, metaLeft='', metaRight='';
  if(s.type === 'volume'){
    width = (s.value / stages[0].value) * 100;
    display = fmtInt(s.value);
    metaRight = `<b>${fmtInt(s.value)}</b><br>${((s.value/stages[0].value)*100).toFixed(2)}% de impresiones`;
  } else {
    width = Math.min(s.value, 100);
    display = fmtPct(s.value);
    metaRight = `<b>${fmtPct(s.value)}</b><br>tasa de conversión de etapa`;
  }
  return `
    <div class="funnel-stage">
      <div class="fs-label"><span class="fs-num">ETAPA ${String(i+1).padStart(2,'0')}</span>${s.label}</div>
      <div class="fs-bar-wrap"><div class="fs-bar" style="width:${width}%">${display}</div></div>
