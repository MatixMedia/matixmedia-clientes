/* ===== 10. SCALE RECOMMENDATIONS ===== */
// Logic:
// SCALE: CPA < 0.85 * account CPA AND Conv > 30 AND ConvRate >= 25
// PAUSE: CPA > 1.5 * account CPA OR (Conv < 10 AND insufficient volume)
// KEEP: middle ground
const recs = DATA.by_campaign.map(c => {
  const cpaRatio = c.CPA / t.cpa;
  let decision, reason, tag;
  if(c.Conv < 10){
    decision = 'pause'; tag='PAUSAR / REESTRUCTURAR';
    reason = `Volumen insuficiente (<b>${fmtNum(c.Conv)} conv.</b>). Sin significancia estadística para optimizar vía Smart Bidding. Fusiona con campaña hermana o aumenta presupuesto agresivamente por 7 días para forzar aprendizaje, o pausa.`;
  } else if(cpaRatio > 1.5){
    decision = 'pause'; tag='PAUSAR O REVISAR';
    reason = `CPA de <b>${fmtMoney(c.CPA)}</b> está <b>${((cpaRatio-1)*100).toFixed(0)}% sobre el promedio</b> de cuenta (${fmtMoney(t.cpa)}). ConvRate de ${fmtPct(c.ConvRate)} indica problema de targeting o landing page. Revisar keyword match types y audiencias antes de pausar.`;
  } else if(cpaRatio <= 0.85 && c.ConvRate >= 25 && c.Conv >= 30){
    decision = 'scale'; tag='ESCALAR +30%';
    reason = `Embudo saludable: CPA <b>${((1-cpaRatio)*100).toFixed(0)}% bajo</b> el promedio, ConvRate de <b>${fmtPct(c.ConvRate)}</b>. Incrementa presupuesto <b>30% esta semana</b>. Si mantiene CPA, otro +30% la siguiente semana.`;
  } else if(cpaRatio <= 1.1){
    decision = 'keep'; tag='MANTENER · OPTIMIZAR';
    reason = `CPA cercano al promedio (${fmtMoney(c.CPA)} vs ${fmtMoney(t.cpa)}). No escalar aún — optimiza primero: revisa search terms report, pausa keywords con 0 conv en últimos 14 días, mejora asset scores.`;
  } else {
    decision = 'keep'; tag='OPTIMIZAR ANTES DE ESCALAR';
    reason = `CPA <b>${((cpaRatio-1)*100).toFixed(0)}% sobre</b> el promedio. Antes de pausar, revisa si la competencia en subasta ha subido (auction insights) o si el Quality Score bajó. Corrige antes de redistribuir presupuesto.`;
  }
  return {c, decision, tag, reason};
});

const order = {scale:0, keep:1, pause:2};
recs.sort((a,b) => order[a.decision] - order[b.decision]);

document.getElementById('rec-grid').innerHTML = recs.map(r => `
  <div class="rec ${r.decision}">
    <div class="rec-head">
      <span class="rec-tag">${r.tag}</span>
    </div>
    <div class="rec-camp">${r.c.Campaña}</div>
    <div class="rec-reason">${r.reason}</div>
    <div class="rec-stats">
      <div>
        <div class="rec-stat-label">Conv.</div>
        <div class="rec-stat-val">${fmtNum(r.c.Conv)}</div>
      </div>
      <div>
        <div class="rec-stat-label">CPA</div>
        <div class="rec-stat-val">${fmtMoney(r.c.CPA)}</div>
      </div>
      <div>
        <div class="rec-stat-label">% Conv.</div>
        <div class="rec-stat-val">${fmtPct(r.c.ConvRate)}</div>
      </div>
    </div>
  </div>
`).join('');

