}).join('');

/* ===== 4. MICRO-CONVERSIONS ===== */
const transitions = [
  {name:'Impresiones → Clics', from:t.impresiones, to:t.clics, benchmark:5},
  {name:'Clics → Conversiones', from:t.clics, to:t.conversiones, benchmark:5},
];
const microBody = document.querySelector('#tbl-micro tbody');
microBody.innerHTML = transitions.map(tr => {
  const retention = (tr.to/tr.from)*100;
  const drop = 100 - retention;
  let health, cls;
  if(retention >= tr.benchmark*2){ health='Excelente'; cls='pos'; }
  else if(retention >= tr.benchmark){ health='Saludable'; cls='pos'; }
  else if(retention >= tr.benchmark*0.5){ health='A mejorar'; cls='warn'; }
  else { health='Crítico'; cls='neg'; }
  return `
    <tr>
      <td class="name">${tr.name}</td>
      <td class="num">${fmtInt(tr.from)}</td>
      <td class="num">${fmtNum(tr.to)}</td>
      <td class="num" style="color:var(--accent-2);font-weight:600">${fmtPct(retention)}</td>
      <td class="num">${fmtPct(drop)}</td>
      <td><span class="card-sub ${cls}" style="font-family:'JetBrains Mono',monospace">● ${health}</span></td>
    </tr>
  `;
}).join('');

