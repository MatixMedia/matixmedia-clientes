/* ===== HELPERS ===== */
const fmtInt = n => Math.round(n).toLocaleString('es-CO');
const fmtNum = n => (Math.round(n*100)/100).toLocaleString('es-CO',{minimumFractionDigits:2,maximumFractionDigits:2});
const fmtMoney = n => '$' + Math.round(n).toLocaleString('es-CO');
const fmtPct = n => (Math.round(n*100)/100).toLocaleString('es-CO',{minimumFractionDigits:2,maximumFractionDigits:2}) + '%';
const diffDays = (a,b) => Math.round((new Date(b)-new Date(a))/(1000*60*60*24)) + 1;

/* ===== DATE PICKER ===== */
function updatePeriod(){
  const from = document.getElementById('date-from').value;
  const to = document.getElementById('date-to').value;
  if(!from || !to) return;
  const f = new Date(from+'T00:00'); const t = new Date(to+'T00:00');
  const days = diffDays(from, to);
  const optsLong = {day:'numeric', month:'long', year:'numeric'};
  const fromStr = f.toLocaleDateString('es-CO', optsLong);
  const toStr = t.toLocaleDateString('es-CO', optsLong);
  document.getElementById('period-display').textContent = `${fromStr} — ${toStr} · ${days} día${days!==1?'s':''}`;
}
document.getElementById('date-from').addEventListener('change', updatePeriod);
document.getElementById('date-to').addEventListener('change', updatePeriod);
updatePeriod();

/* ===== 1. METRIC CARDS ===== */
const t = DATA.totals;
const cardDefs = [
  {k:'impresiones', label:'Impresiones', value:fmtInt(t.impresiones), sub:'Volumen de vista'},
  {k:'clics', label:'Clics', value:fmtInt(t.clics), sub:'CPC ' + fmtMoney(t.cpc)},
  {k:'ctr', label:'CTR', value:fmtPct(t.ctr), sub: t.ctr>=5?'Saludable para Search':'Bajo — revisar creative', cls: t.ctr>=5?'pos':'warn'},
  {k:'conv', label:'Conversiones', value:fmtNum(t.conversiones), sub:'Leads capturados'},
  {k:'convRate', label:'% Conversión', value:fmtPct(t.conv_rate), sub: t.conv_rate>15?'⚠ Revisar definición':'Normal', cls: t.conv_rate>15?'warn':'pos'},
  {k:'costo', label:'Costo Total', value:fmtMoney(t.costo), sub:'CPA ' + fmtMoney(t.cpa)},
];
const cards = document.getElementById('cards');
cards.innerHTML = cardDefs.map((c,i) => `
  <div class="card" data-metric="${c.k}">
    <div class="card-label">${String(i+1).padStart(2,'0')} · ${c.label}</div>
    <div class="card-value">${c.value}</div>
    <div class="card-sub ${c.cls||''}">${c.sub}</div>
  </div>
`).join('');

// Card click → toggle active
let activeMetric = null;
cards.querySelectorAll('.card').forEach(card => {
  card.addEventListener('click', () => {
    const m = card.dataset.metric;
    cards.querySelectorAll('.card').forEach(c => c.classList.remove('active'));
    if(activeMetric !== m){ card.classList.add('active'); activeMetric = m; }
    else activeMetric = null;
    highlightTables(activeMetric);
  });
});

function highlightTables(metric){
  // Add visual highlight to related columns
  document.querySelectorAll('th, td').forEach(el => el.style.background = '');
  const map = {clics:'Clics', conv:'Conv', costo:'Costo', convRate:'ConvRate', ctr:'CTR', impresiones:'Impr'};
  if(!metric || !map[metric]) return;
  const target = map[metric];
  document.querySelectorAll('th').forEach(th => {
    if(th.dataset.sort === target){
      const idx = th.cellIndex;
      const tbl = th.closest('table');
      if(tbl){
        tbl.querySelectorAll('tr').forEach(tr => {
          const cell = tr.cells[idx];
          if(cell) cell.style.background = 'rgba(216,165,87,0.07)';
        });
      }
    }
  });
}

/* ===== 2. SERIES TABLE (sortable) ===== */
function renderSeriesTable(sortKey='Conv', sortDir='desc'){
  const rows = [...DATA.by_campaign].sort((a,b) => {
    const av = a[sortKey], bv = b[sortKey];
    if(typeof av === 'string') return sortDir==='asc' ? av.localeCompare(bv) : bv.localeCompare(av);
    return sortDir==='asc' ? av-bv : bv-av;
  });
  const tbody = document.querySelector('#tbl-series tbody');
  const maxConv = Math.max(...rows.map(r=>r.Conv));
  tbody.innerHTML = rows.map(r => `
    <tr>
      <td class="name">${r.Campaña}</td>
      <td class="num">${fmtInt(r.Clics)}</td>
      <td class="num bar-cell">
        <div class="bar-fill" style="width:${(r.Conv/maxConv*100)||0}%"></div>
        <span>${fmtNum(r.Conv)}</span>
      </td>
      <td class="num">${fmtMoney(r.Costo)}</td>
      <td class="num">${fmtMoney(r.CPA)}</td>
      <td class="num">${fmtPct(r.ConvRate)}</td>
    </tr>
  `).join('');
  // Update arrow states
  document.querySelectorAll('#tbl-series th.sortable').forEach(th => {
    th.classList.toggle('sorted', th.dataset.sort === sortKey);
  });
}
let seriesState = {key:'Conv', dir:'desc'};
renderSeriesTable();
document.querySelectorAll('#tbl-series th.sortable').forEach(th => {
  th.addEventListener('click', () => {
    const k = th.dataset.sort;
    if(seriesState.key === k) seriesState.dir = seriesState.dir==='asc'?'desc':'asc';
    else { seriesState.key = k; seriesState.dir = 'desc'; }
    renderSeriesTable(seriesState.key, seriesState.dir);
  });
});

