/* ===== 7. EXTENSIONS ===== */
function renderExtTable(sortKey='Conv', sortDir='desc'){
  const rows = [...DATA.top_extensions].sort((a,b) => {
    const av = a[sortKey], bv = b[sortKey];
    if(typeof av === 'string') return sortDir==='asc' ? av.localeCompare(bv) : bv.localeCompare(av);
    return sortDir==='asc' ? av-bv : bv-av;
  });
  const tbody = document.querySelector('#tbl-ext tbody');
  const maxConv = Math.max(...rows.map(r=>r.Conv));
  tbody.innerHTML = rows.map(r => {
    const retainCls = r.ConvRate >= 30 ? 'pos' : (r.ConvRate >= 15 ? 'warn' : 'neg');
    return `
      <tr>
        <td class="name" style="max-width:380px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="${r.Ext_clean}">${r.Ext_clean}</td>
        <td class="num">${fmtInt(r.Impr)}</td>
        <td class="num">${fmtInt(r.Clics)}</td>
        <td class="num">${fmtPct(r.CTR)}</td>
        <td class="num bar-cell">
          <div class="bar-fill" style="width:${(r.Conv/maxConv*100)||0}%"></div>
          <span>${fmtNum(r.Conv)}</span>
        </td>
        <td class="num" style="color:var(--${retainCls==='pos'?'green':retainCls==='warn'?'amber':'red'})">${fmtPct(r.ConvRate)}</td>
        <td class="num">${r.CPA > 0 ? fmtMoney(r.CPA) : '—'}</td>
      </tr>
    `;
  }).join('');
  document.querySelectorAll('#tbl-ext th.sortable').forEach(th => {
    th.classList.toggle('sorted', th.dataset.sort === sortKey);
  });
}
let extState = {key:'Conv', dir:'desc'};
renderExtTable();
document.querySelectorAll('#tbl-ext th.sortable').forEach(th => {
  th.addEventListener('click', () => {
    const k = th.dataset.sort;
    if(extState.key === k) extState.dir = extState.dir==='asc'?'desc':'asc';
    else { extState.key = k; extState.dir = 'desc'; }
    renderExtTable(extState.key, extState.dir);
  });
});

/* ===== 8. RANKING ===== */
const rankBody = document.querySelector('#tbl-rank tbody');
const rankRows = [...DATA.by_campaign].sort((a,b) => b.Conv - a.Conv);
