rankBody.innerHTML = rankRows.map((r,i) => {
  // Need campaign type — infer from DATA or default
  const type = (r.Campaña.includes('PMAX') ? 'Máx. Rendimiento' : 'Búsqueda');
  const share = (r.Conv/totalConvRank*100);
  return `
    <tr>
